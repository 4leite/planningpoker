{
  "name": "planningpoker",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "check": "pnpm format:check && pnpm lint:check && pnpm tsc && pnpm test",
    "build": "vite build",
    "typegen": "wrangler types",
    "deploy": "pnpm build && wrangler deploy",
    "deploy:dry-run": "pnpm build && wrangler deploy --dry-run",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --fix .",
    "lint:check": "oxlint .",
    "prepare": "simple-git-hooks",
    "preview": "vite preview --host 127.0.0.1 --port 3000 --strictPort",
    "preview:e2e": "pnpm build && pnpm preview",
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "test:interactive": "playwright test --project main --grep @manual --headed --workers=1",
    "test:playwright": "playwright test",
    "test:e2e": "playwright test --project main --grep-invert '@manual|@stress'",
    "test:e2e:headed": "playwright test --project main --headed --grep-invert @manual",
    "test:e2e:smoke": "playwright test --project main --grep @smoke --grep-invert '@manual|@stress'",
    "test:e2e:stress": "playwright test --project main --grep @stress --grep-invert @manual",
    "validate": "pnpm check && pnpm test:e2e",
    "wrangler": "wrangler"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@radix-ui/react-icons": "^1.3.2",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-devtools": "^5.100.1",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "@tohuhono/ui": "^0.14.7",
    "@tohuhono/utils": "^0.14.1",
    "human-id": "^4.1.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.33.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.7.2",
    "vite": "^8.0.0",
    "vitest": "^3.0.5",
    "wrangler": "^4.84.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run format"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
