{
  "name": "planningpoker",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "preview": "vite preview --host 127.0.0.1 --port 3000 --strictPort",
    "preview:e2e": "pnpm build && pnpm preview",
    "deploy": "pnpm build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "lint": "oxlint --fix .",
    "lint:check": "oxlint .",
    "tsc": "tsc --noEmit",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "validate": "pnpm lint:check && pnpm tsc && pnpm test && pnpm test:e2e:smoke && pnpm format:check",
    "prepare": "simple-git-hooks",
    "test": "vitest run",
    "test:interactive": "playwright test --grep @manual --headed --workers=1",
    "test:playwright": "playwright test",
    "test:e2e": "playwright test --grep-invert @manual",
    "test:e2e:headed": "playwright test --headed --grep-invert @manual",
    "test:e2e:smoke": "playwright test --grep @smoke --grep-invert '@manual|@stress'",
    "test:e2e:stress": "playwright test --grep @stress --grep-invert @manual",
    "docker": "pnpm docker:down && pnpm docker:up && pnpm docker:log",
    "docker:build": "podman build --storage-opt ignore_chown_errors=true -t localhost/planningpoker-e2e:latest -f Dockerfile . ",
    "docker:start": "podman run --replace --rm --name planning-poker-e2e --userns keep-id -p 3000:3000 --mount type=tmpfs,destination=/data localhost/planningpoker-e2e:latest",
    "docker:up": "pnpm docker:build && pnpm docker:start",
    "docker:down": "podman rm -f planning-poker-e2e || true",
    "docker:log": "podman logs -f  --tail 100 planning-poker-e2e"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@radix-ui/react-icons": "^1.3.2",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "@tohuhono/ui": "^0.14.6",
    "@tohuhono/utils": "^0.14.1",
    "human-id": "^4.1.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "redis": "^5.12.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.33.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "globals": "^17.5.0",
    "jsdom": "^28.1.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.7.2",
    "vite": "^8.0.0",
    "vitest": "^3.0.5",
    "wrangler": "^4.84.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run format"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
