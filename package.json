{
  "name": "planningpoker",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "preview": "vite preview",
    "prepare": "simple-git-hooks",
    "prettier": "prettier --check \"**/*.{ts,tsx,js,jsx,css,md,mdx,json}\"",
    "prettier:fix": "prettier -l --write \"**/*.{ts,tsx,js,jsx,css,md,mdx,json}\"",
    "test": "vitest run"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run prettier:fix"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@radix-ui/react-icons": "^1.3.2",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "@tohuhono/ui": "^0.14.6",
    "@tohuhono/utils": "^0.14.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript-eslint": "^8.58.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/utils": "^8.58.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "jsdom": "^28.1.0",
    "nitro": "npm:nitro-nightly@3.0.1-20260415-080922-45e20aaa",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.7.2",
    "vite": "^8.0.0",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
